PORT=3001
DATABASE_URL="postgresql://postgres:password@localhost:5432/carepath"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
NODE_ENV="development"

# Allowed CORS origins in production (comma-separated)
# Set this to your Vercel UI URL once deployed
# Example: ALLOWED_ORIGINS="https://carepath-ui.vercel.app"
ALLOWED_ORIGINS=""

# Twilio (optional for pilot — leave blank to use dry-run SMS logging)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
